{
  "name": "family-newyear-calendar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "mock": "json-server --watch mock/db.json --port 4000 --middlewares mock/middleware.cjs",
    "dev:all": "concurrently \"npm run dev\" \"npm run mock\""
  },
  "dependencies": {
    "solid-js": "^1.8.15",
    "@fullcalendar/core": "^6.1.11",
    "@fullcalendar/daygrid": "^6.1.11",
    "@fullcalendar/timegrid": "^6.1.11",
    "@fullcalendar/interaction": "^6.1.11",
    "@fullcalendar/list": "^6.1.11",
    "luxon": "^3.4.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.1.3",
    "lunar-javascript": "^1.6.12",
    "ics": "^3.7.2"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "vite-plugin-solid": "^2.10.2",
    "typescript": "^5.4.5",
    "@types/luxon": "^3.4.2",
    "json-server": "^0.17.4",
    "concurrently": "^8.2.2"
  }
}
